PRIMITIVA_USUARIO=tu_email_o_dni
PRIMITIVA_PASSWORD=tu_contraseña

# Opcional: número de apuestas fijo (1-8). Si no se define, el script lo pregunta.
PRIMITIVA_APUESTAS=

# Opcional: saltar la confirmación de los números generados (si=no pregunta, cualquier otro valor=pregunta)
PRIMITIVA_CONFIRMAR_NUMEROS=

# Opcional: saltar la confirmación de pago. CUIDADO: activar esto ejecuta el pago sin preguntar.
PRIMITIVA_CONFIRMAR_PAGO=
